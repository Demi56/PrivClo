<!--
  角色管理 - 角色切换 / 信息录入
-->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">角色管理</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="main">
    <view class="pill-card" bindtap="onRoleSwitch">
      <view class="pill-icon pill-icon-switch">
        <view class="pill-icon-inner icon-switch"></view>
      </view>
      <view class="pill-content">
        <text class="pill-title">角色切换</text>
        <text class="pill-desc">切换当前使用的穿搭角色</text>
      </view>
      <view class="pill-arrow"></view>
    </view>

    <view class="pill-card" bindtap="onRoleProfile">
      <view class="pill-icon pill-icon-profile">
        <view class="pill-icon-inner icon-profile"></view>
      </view>
      <view class="pill-content">
        <text class="pill-title">信息录入</text>
        <text class="pill-desc">昵称、身高体重、三围与风格标签</text>
      </view>
      <view class="pill-arrow"></view>
    </view>
  </view>
</view>
