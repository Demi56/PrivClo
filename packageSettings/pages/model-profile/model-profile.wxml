<!-- 角色信息录入 - 与首页「角色信息录入」弹窗同款表单样式 -->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="header">
    <view class="header-back" bindtap="onCancel">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">信息录入</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="scroll-main" scroll-y>
    <view class="card-wrap">
      <view class="role-entry-card">
        <view class="role-entry-avatar-wrap">
          <image
            class="role-entry-avatar"
            src="{{gender === 'male' ? roleAvatarMaleUrl : roleAvatarFemaleUrl}}"
            mode="aspectFill"
          />
        </view>
        <view class="role-entry-form">
          <view class="role-field">
            <text class="role-label">角色昵称</text>
            <input
              class="role-input"
              placeholder="请输入角色昵称"
              value="{{roleNickname}}"
              bindinput="onRoleNicknameInput"
            />
          </view>
          <view class="role-field-row">
            <view class="role-field half">
              <text class="role-label">身高 (cm)</text>
              <input
                class="role-input"
                type="number"
                placeholder="168"
                value="{{roleHeight}}"
                bindinput="onRoleHeightInput"
              />
            </view>
            <view class="role-field half">
              <text class="role-label">体重 (kg)</text>
              <input
                class="role-input"
                type="number"
                placeholder="48"
                value="{{roleWeight}}"
                bindinput="onRoleWeightInput"
              />
            </view>
          </view>
          <view class="role-field">
            <view class="role-label-row">
              <text class="role-label {{roleBustWaistHipEnabled ? '' : 'role-label-muted'}}">三围 (胸/腰/臀)</text>
              <switch
                class="role-switch"
                checked="{{roleBustWaistHipEnabled}}"
                bindchange="onToggleBustWaistHip"
                color="#4DD0E1"
              />
            </view>
            <input
              wx:if="{{roleBustWaistHipEnabled}}"
              class="role-input"
              placeholder="84 / 62 / 88"
              value="{{roleBustWaistHip}}"
              bindinput="onRoleBustWaistHipInput"
            />
          </view>
        </view>

        <view class="style-section">
          <text class="role-label">喜欢的风格</text>
          <view class="tags">
            <view
              wx:for="{{styleOptions}}"
              wx:key="*this"
              class="tag {{selectedStyles.indexOf(item) >= 0 ? 'selected' : ''}}"
              data-name="{{item}}"
              bindtap="toggleStyle"
            >{{item}}</view>
          </view>
        </view>

        <view class="role-entry-actions">
          <view class="role-btn role-btn-save" bindtap="onSave">保存修改</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
