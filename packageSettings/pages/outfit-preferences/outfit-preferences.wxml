<wxs module="m">
function hasStyle(arr, id) {
  if (!arr || !(arr.length > 0)) return false;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === id) return true;
  }
  return false;
}
module.exports.hasStyle = hasStyle;
</wxs>
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="blur-bg"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">穿搭偏好</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="scroll-main" scroll-y>
    <view class="card-wrap">
      <view class="card">
        <text class="card-desc">精灵小助手会记住您的偏好，推荐时自动避开不喜欢的单品，优先推荐您喜欢的～</text>
        <view class="field">
          <text class="label">不喜欢的单品</text>
          <textarea class="textarea" placeholder="如：裙子、高跟鞋、紧身裤（多个用顿号或逗号分隔）" value="{{avoidItems}}" bindinput="onAvoidInput" maxlength="200" />
        </view>
        <view class="field">
          <text class="label">喜欢的单品</text>
          <textarea class="textarea" placeholder="如：宽松款、运动鞋、卫衣（多个用顿号或逗号分隔）" value="{{preferItems}}" bindinput="onPreferInput" maxlength="200" />
        </view>

        <view class="section-divider"></view>
        <text class="section-heading">基础资料</text>

        <view class="field">
          <view class="field-row">
            <text class="label">年龄</text>
            <text class="age-value">{{age}}岁</text>
          </view>
          <view class="slider-wrap">
            <slider class="slider" min="12" max="100" value="{{age}}" activeColor="#66CCAA" backgroundColor="#E8E8E8" block-size="24" block-color="#FFFFFF" show-value="{{false}}" bindchange="onAgeChange" />
          </view>
          <view class="slider-labels">
            <text class="slider-label">12</text>
            <text class="slider-label">100</text>
          </view>
        </view>

        <view class="field field-style">
          <view class="field-row">
            <text class="label">风格偏好</text>
            <text class="section-hint">可多选</text>
          </view>
          <view class="tags">
            <view class="tag {{m.hasStyle(styleTags, '日常休闲风') ? 'selected' : ''}}" data-id="日常休闲风" bindtap="toggleStyle">日常休闲风</view>
            <view class="tag {{m.hasStyle(styleTags, '法式风') ? 'selected' : ''}}" data-id="法式风" bindtap="toggleStyle">法式风</view>
            <view class="tag {{m.hasStyle(styleTags, '商务职场风') ? 'selected' : ''}}" data-id="商务职场风" bindtap="toggleStyle">商务职场风</view>
            <view class="tag {{m.hasStyle(styleTags, '运动风') ? 'selected' : ''}}" data-id="运动风" bindtap="toggleStyle">运动风</view>
            <view class="tag {{m.hasStyle(styleTags, '极简风') ? 'selected' : ''}}" data-id="极简风" bindtap="toggleStyle">极简风</view>
            <view class="tag {{m.hasStyle(styleTags, '复古风') ? 'selected' : ''}}" data-id="复古风" bindtap="toggleStyle">复古风</view>
            <view class="tag {{m.hasStyle(styleTags, '街头潮酷') ? 'selected' : ''}}" data-id="街头潮酷" bindtap="toggleStyle">街头潮酷</view>
            <view class="tag {{m.hasStyle(styleTags, '新中式') ? 'selected' : ''}}" data-id="新中式" bindtap="toggleStyle">新中式</view>
            <view class="tag tag-more {{showMoreStyles ? 'expanded' : ''}}" bindtap="toggleMoreStyles">{{moreStylesBtnText}}</view>
          </view>
          <view wx:if="{{showMoreStyles}}" class="tags tags-more">
            <view class="tag {{m.hasStyle(styleTags, '汉服') ? 'selected' : ''}}" data-id="汉服" bindtap="toggleStyle">汉服</view>
            <view class="tag {{m.hasStyle(styleTags, 'JK') ? 'selected' : ''}}" data-id="JK" bindtap="toggleStyle">JK</view>
            <view class="tag {{m.hasStyle(styleTags, '洛丽塔') ? 'selected' : ''}}" data-id="洛丽塔" bindtap="toggleStyle">洛丽塔</view>
            <view class="tag {{m.hasStyle(styleTags, 'Vintage') ? 'selected' : ''}}" data-id="Vintage" bindtap="toggleStyle">Vintage</view>
            <view class="tag {{m.hasStyle(styleTags, '山系户外') ? 'selected' : ''}}" data-id="山系户外" bindtap="toggleStyle">山系户外</view>
          </view>
        </view>

        <view class="actions">
          <view class="btn btn-cancel" bindtap="onBack">取消</view>
          <view class="btn btn-save" bindtap="onSave">保存</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
