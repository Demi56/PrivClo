<wxs module="m">
function hasStyle(arr, id) {
  if (!arr || !(arr.length > 0)) return false;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === id) return true;
  }
  return false;
}
module.exports.hasStyle = hasStyle;
</wxs>
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="blur-bg"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">穿搭偏好</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="scroll-main" scroll-y>
    <view class="card-wrap">
      <view class="card">
        <text class="card-desc">精灵小管家会记住您的偏好，推荐时自动避开不喜欢的单品，优先推荐您喜欢的～</text>
        <view class="field">
          <text class="label">不喜欢的单品</text>
          <textarea class="textarea" auto-height placeholder="如：裙子、高跟鞋、紧身裤（多个用顿号或逗号分隔）" value="{{avoidItems}}" bindinput="onAvoidInput" maxlength="200" />
        </view>
        <view class="field">
          <text class="label">喜欢的单品</text>
          <textarea class="textarea" auto-height placeholder="如：宽松款、运动鞋、卫衣（多个用顿号或逗号分隔）" value="{{preferItems}}" bindinput="onPreferInput" maxlength="200" />
        </view>

        <view class="section-divider"></view>

        <view class="field field-style">
          <view class="field-row">
            <text class="label">风格偏好</text>
            <text class="section-hint">可多选</text>
          </view>
          <view class="tags">
            <view
              wx:for="{{styleDisplayOptions}}"
              wx:key="*this"
              class="tag {{m.hasStyle(styleTags, item) ? 'selected' : ''}}"
              data-id="{{item}}"
              bindtap="toggleStyle"
            >{{item}}</view>
            <view class="tag tag-add" bindtap="onAddCustomStyle">+</view>
          </view>
        </view>

        <view class="actions">
          <view class="btn btn-cancel" bindtap="onBack">取消</view>
          <view class="btn btn-save" bindtap="onSave">保存</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{showStyleAddPopup}}" class="style-add-mask" catchtap="onCloseStyleAddPopup"></view>
  <view wx:if="{{showStyleAddPopup}}" class="style-add-popup">
    <view class="style-add-title">自定义风格</view>
    <input
      class="style-add-input"
      value="{{editingStyleName}}"
      placeholder="请输入风格名称"
      maxlength="12"
      focus="{{showStyleAddPopup}}"
      bindinput="onStyleNameInput"
    />
    <view class="style-add-btns">
      <view class="style-add-btn" catchtap="onConfirmCustomStyle">确定</view>
      <view class="style-add-btn secondary" catchtap="onCloseStyleAddPopup">取消</view>
    </view>
  </view>
</view>
