<view class="spine-model" style="opacity: {{canvasOpacity}};">
  <!-- Spine WebGL 画布（加载成功时显示） -->
  <canvas
    wx:if="{{spineReady}}"
    id="spineCanvas"
    type="webgl"
    class="spine-canvas"
    disable-scroll="{{true}}"
    bindtap="onCanvasTap"
    bindtouchstart="onCanvasTouchStart"
    bindtouchmove="onCanvasTouchMove"
  />

  <!-- 降级：Spine 加载失败时使用静态底图+PNG贴图 -->
  <model-tryon
    wx:if="{{fallbackMode}}"
    id="fallbackTryon"
    class="spine-fallback"
    gender="{{gender}}"
    outfit="{{outfit}}"
  />

  <view wx:if="{{loading}}" class="spine-loading">
    <text>加载中...</text>
  </view>
</view>
