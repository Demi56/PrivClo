.recommend-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  margin-bottom: 24rpx;
}

.style-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: var(--theme-primary-dark, #38BDF8);
  color: #fff;
  font-size: 26rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.reason {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.copywriting {
  display: block;
  font-size: 26rpx;
  color: #6ec5d9;
  line-height: 1.4;
}

.items-section {
  border-top: 1rpx solid #eee;
  padding-top: 24rpx;
}

.item-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.item-row .label {
  width: 100rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.item-row .value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.tips-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 28rpx;
  color: var(--theme-text-secondary, #4B5563);
  line-height: 1.5;
}

.ai-disclaimer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--theme-border-soft, #D4EDFA);
  text-align: center;
}

.ai-disclaimer-text {
  font-size: 24rpx;
  color: var(--theme-deep-blue, #0EA5E9);
  font-weight: 500;
}
