<!--
  精灵小管家 - 可折叠聊天助手组件
  点击头像展开；仅右上角删除按钮可关闭；对话历史本地持久化
-->
<view class="chat-assistant">
  <!-- 折叠态：浮动头像，点击展开（expanded 由父级传入时不显示） -->
  <view wx:if="{{!expanded && !internalExpanded}}" class="chat-avatar-wrap" bindtap="onOpenPanel">
    <image class="chat-avatar-img" src="{{avatarUrl}}" mode="aspectFit" />
    <view wx:if="{{unreadCount > 0}}" class="chat-avatar-badge">{{unreadCount > 9 ? '9+' : unreadCount}}</view>
  </view>

  <!-- 展开态：聊天面板 -->
  <view wx:elif="{{expanded || internalExpanded}}" class="chat-panel-wrap">
    <view class="chat-panel-mask"></view>
    <view class="chat-panel">
      <view class="chat-header">
        <view class="chat-header-text">
          <text class="chat-title">精灵小管家</text>
          <text class="chat-ai-tag">AI 生成 · 仅供参考</text>
        </view>
        <view class="chat-close-btn" bindtap="onClosePanel">×</view>
      </view>
      <scroll-view
        class="chat-messages"
        scroll-y
        scroll-into-view="{{scrollToId}}"
        scroll-with-animation
        bindscrolltolower="onScrollToLower"
      >
        <block wx:for="{{messages}}" wx:key="id">
          <view wx:if="{{item.showTimeLabel}}" class="chat-time-label">
            <text class="chat-time-text">{{item.timeLabel}}</text>
          </view>
          <view id="msg-{{item.id}}" class="chat-msg {{item.role === 'user' ? 'chat-msg-user' : 'chat-msg-assistant'}}">
            <image class="chat-msg-avatar" src="{{item.role === 'user' ? userAvatar : spriteAvatar}}" mode="aspectFill" />
            <view class="chat-msg-bubble-wrap">
              <view class="chat-msg-bubble">
                <image
                  wx:if="{{item.imageUrl}}"
                  class="chat-msg-image"
                  src="{{item.imageUrl}}"
                  mode="widthFix"
                  bindtap="onPreviewImage"
                  data-url="{{item.imageUrl}}"
                />
                <text wx:if="{{item.content}}" class="chat-msg-text">{{item.content}}</text>
              </view>
              <text wx:if="{{item.role === 'assistant' && item.content}}" class="chat-msg-ai-note">AI 生成 · 仅供参考</text>
              <view wx:if="{{item.role === 'assistant' && item.id}}" class="chat-msg-feedback">
                <view class="chat-feedback-btn {{item.feedback === 'up' ? 'active' : ''}}" bindtap="onFeedbackUp" data-id="{{item.id}}">👍</view>
                <view class="chat-feedback-btn {{item.feedback === 'down' ? 'active' : ''}}" bindtap="onFeedbackDown" data-id="{{item.id}}">👎</view>
              </view>
            </view>
          </view>
        </block>
        <view wx:if="{{loading}}" class="chat-msg chat-msg-assistant">
          <image class="chat-msg-avatar" src="{{spriteAvatar}}" mode="aspectFill" />
          <view class="chat-msg-bubble-wrap">
            <view class="chat-msg-bubble chat-msg-loading">
              <text class="chat-msg-text">正在输入...</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view wx:if="{{pendingImage}}" class="chat-pending-wrap">
        <view class="chat-pending-card">
          <image class="chat-pending-img" src="{{pendingImage.previewUrl}}" mode="aspectFill" bindtap="onPreviewImage" data-url="{{pendingImage.previewUrl}}" />
          <view wx:if="{{uploadingImage}}" class="chat-pending-mask">上传中...</view>
          <view class="chat-pending-remove" catchtap="onRemovePendingImage">×</view>
        </view>
        <text class="chat-pending-tip">已选图片，可补充文字后发送</text>
      </view>
      <view class="chat-input-wrap">
        <view class="chat-image-btn {{loading || uploadingImage ? 'chat-image-btn-disabled' : ''}}" catchtap="onPickImage">
          <view class="chat-image-btn-icon"></view>
        </view>
        <input
          class="chat-input"
          placeholder="问问精灵穿搭建议，或发送照片～"
          value="{{inputText}}"
          bindinput="onInput"
          confirm-type="send"
          bindconfirm="onSend"
          focus="{{inputFocus}}"
        />
        <view class="chat-send-btn {{(inputText || pendingImage) && !loading && !uploadingImage ? '' : 'chat-send-disabled'}}" bindtap="onSend">发送</view>
      </view>
    </view>
  </view>
</view>
