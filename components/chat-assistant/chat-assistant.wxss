/* 精灵小管家 - 可折叠聊天助手 */

.chat-assistant {
  position: relative;
}

/* 折叠态：浮动头像（与精灵尺寸一致） */
.chat-avatar-wrap {
  position: relative;
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.chat-avatar-img {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #A8D8F0 0%, #B8E0F0 100%);
}

.chat-avatar-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #FFF;
  background: #FF5722;
  border-radius: 16rpx;
  text-align: center;
}

/* 展开态：聊天面板（页面级浮层，确保在 Tab 等之上） */
.chat-panel-wrap {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.chat-panel-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 0;
}

.chat-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-height: 75vh;
  background: #FBF8F5;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.chat-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.chat-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  color: #666;
  font-size: 36rpx;
  line-height: 52rpx;
  text-align: center;
}

.chat-messages {
  flex: 1;
  height: 400rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.chat-time-label {
  display: flex;
  justify-content: center;
  margin: 4rpx 0 20rpx;
}

.chat-time-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.4;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.04);
}

.chat-msg {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.chat-msg-avatar {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8E8E8 0%, #F0F0F0 100%);
}

.chat-msg-user {
  flex-direction: row-reverse;
}

.chat-msg-assistant {
  flex-direction: row;
}

.chat-msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.chat-msg-user .chat-msg-bubble {
  background: #4DD0E1;
  color: #FFF;
  border-bottom-right-radius: 8rpx;
}

.chat-msg-assistant .chat-msg-bubble {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-bottom-left-radius: 8rpx;
}

.chat-msg-bubble-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 75%;
}

.chat-msg-user .chat-msg-bubble-wrap {
  align-items: flex-end;
}

.chat-msg-feedback {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 8rpx;
}

.chat-feedback-btn {
  font-size: 24rpx;
  opacity: 0.5;
  padding: 4rpx 8rpx;
}

.chat-feedback-btn.active {
  opacity: 1;
}

.chat-msg-loading {
  color: #999;
}

.chat-input-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFF;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
}

.chat-send-btn {
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFF;
  background: #4DD0E1;
  border-radius: 36rpx;
}

.chat-send-disabled {
  background: #CCC;
  color: #999;
}
