/* 精灵小管家 - 冰蓝主题 */

.chat-assistant {
  position: relative;
}

.chat-avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(56, 189, 248, 0.28);
}

.chat-avatar-img {
  width: 100%;
  height: 100%;
  background: var(--theme-gradient-soft, linear-gradient(180deg, #FFFFFF 0%, #EFF6FC 40%, #D4EDFA 100%));
}

.chat-avatar-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: var(--theme-deep-blue, #0EA5E9);
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(14, 165, 233, 0.35);
}

.chat-panel-wrap {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.chat-panel-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.35);
  z-index: 0;
}

.chat-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-height: 75vh;
  background: var(--theme-gradient-soft, linear-gradient(180deg, #FFFFFF 0%, #EFF6FC 40%, #D4EDFA 100%));
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -12rpx 48rpx rgba(125, 211, 252, 0.22);
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--theme-border-soft, #D4EDFA);
  background: rgba(255, 255, 255, 0.72);
}

.chat-header-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.chat-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--theme-text, #1F2937);
}

.chat-ai-tag {
  font-size: 22rpx;
  color: var(--theme-deep-blue, #0EA5E9);
  font-weight: 500;
}

.chat-msg-ai-note {
  display: block;
  font-size: 20rpx;
  color: var(--theme-deep-blue, #0EA5E9);
  margin-top: 6rpx;
  padding-left: 4rpx;
}

.chat-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  color: var(--theme-deep-blue, #0EA5E9);
  font-size: 36rpx;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(125, 211, 252, 0.15);
}

.chat-messages {
  flex: 1;
  height: 400rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.chat-time-label {
  display: flex;
  justify-content: center;
  margin: 4rpx 0 20rpx;
}

.chat-time-text {
  font-size: 22rpx;
  color: var(--theme-text-secondary, #4B5563);
  line-height: 1.4;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid var(--theme-border-soft, #D4EDFA);
}

.chat-msg {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.chat-msg-avatar {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--theme-bg-subtle, #EFF6FC);
  border: 2rpx solid var(--theme-border-soft, #D4EDFA);
}

.chat-msg-user {
  flex-direction: row-reverse;
}

.chat-msg-assistant {
  flex-direction: row;
}

.chat-msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.chat-msg-user .chat-msg-bubble {
  background: var(--theme-primary-dark, #38BDF8);
  color: #FFFFFF;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(56, 189, 248, 0.25);
}

.chat-msg-assistant .chat-msg-bubble {
  background: rgba(255, 255, 255, 0.95);
  color: var(--theme-text, #1F2937);
  border: 2rpx solid var(--theme-border-soft, #D4EDFA);
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(125, 211, 252, 0.1);
}

.chat-msg-bubble-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 75%;
}

.chat-msg-user .chat-msg-bubble-wrap {
  align-items: flex-end;
}

.chat-msg-feedback {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 8rpx;
}

.chat-feedback-btn {
  font-size: 24rpx;
  opacity: 0.45;
  padding: 4rpx 8rpx;
}

.chat-feedback-btn.active {
  opacity: 1;
  color: var(--theme-deep-blue, #0EA5E9);
}

.chat-msg-loading {
  color: var(--theme-text-secondary, #4B5563);
}

.chat-input-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  border-top: 1rpx solid var(--theme-border-soft, #D4EDFA);
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--theme-text, #1F2937);
  background: var(--theme-bg-subtle, #EFF6FC);
  border: 2rpx solid var(--theme-border-soft, #D4EDFA);
  border-radius: 36rpx;
  box-sizing: border-box;
}

.chat-send-btn {
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: var(--theme-primary-dark, #38BDF8);
  border-radius: 36rpx;
  box-shadow: 0 6rpx 20rpx rgba(56, 189, 248, 0.3);
}

.chat-send-disabled {
  background: var(--theme-tab-inactive, #D1D5DB);
  color: #FFFFFF;
  box-shadow: none;
}
