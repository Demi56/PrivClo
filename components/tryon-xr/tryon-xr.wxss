.tryon-xr-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #f5f0e8;
  border-radius: 16rpx;
}

tryon-xr,
.tryon-xr-wrap xr-scene {
  display: block;
  width: 100%;
  height: 100%;
}

.tryon-xr-loading {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #888;
  pointer-events: none;
}
