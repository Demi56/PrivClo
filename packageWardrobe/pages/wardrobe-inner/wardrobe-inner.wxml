<!--
  衣橱内页 - 衣物分区
  可滚动：上衣区等 6 个分类卡片
  底部固定：扫描录入单品按钮
-->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <view class="header-wardrobe-nav">
      <view
        class="header-nav-item {{wardrobeNavTab === 'resale' ? 'header-nav-active' : ''}}"
        catchtap="onWardrobeNavTap"
        data-tab="resale"
      >闲置区</view>
      <view class="header-nav-divider"></view>
      <view
        class="header-nav-item {{wardrobeNavTab === 'favorites' ? 'header-nav-active' : ''}}"
        catchtap="onWardrobeNavTap"
        data-tab="favorites"
      >收藏区</view>
    </view>
    <view class="header-placeholder"></view>
  </view>

  <!-- 可滚动：衣物分区 -->
  <scroll-view class="categories-scroll" scroll-y style="top: {{scrollAreaTop}}px; bottom: {{scrollAreaBottom}}px;">
    <view class="categories-inner">
      <view wx:for="{{categories}}" wx:key="id" class="category-card category-card-{{item.id}}" bindtap="onCategoryTap" data-id="{{item.id}}">
        <image wx:if="{{item.cover}}" class="category-cover" src="{{item.cover}}" mode="aspectFill" />
        <view class="category-bg"></view>
        <view class="category-info">
          <text class="category-name">{{item.name}}</text>
          <text class="category-count">{{item.count}}{{item.unit}}</text>
        </view>
      </view>
      <view class="categories-bottom-spacer"></view>
    </view>
  </scroll-view>

  <!-- 固定底部：扫描录入单品 -->
  <view class="scan-footer">
    <button class="scan-btn" bindtap="onScanInput">
      <view class="scan-icon"></view>
      <text class="scan-text">扫描录入单品</text>
    </button>
  </view>

</view>
