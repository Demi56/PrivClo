/* 3D 模特全身穿搭展示页面 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F8F8 50%, #F0F0F0 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.status-bar { width: 100%; flex-shrink: 0; }

/* 左上角天气胶囊（top 由 inline style 根据状态栏动态设置） */
.weather-capsule {
  position: fixed;
  left: 24rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 48rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  z-index: 10;
}

.weather-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weather-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
}

.weather-icon-sun {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
}

.weather-icon-cloud {
  background: linear-gradient(135deg, #B0BEC5 0%, #90A4AE 100%);
}

.weather-icon-cloudy {
  background: linear-gradient(135deg, #78909C 0%, #607D8B 100%);
}

.weather-icon-rain {
  background: linear-gradient(135deg, #4FC3F7 0%, #29B6F6 100%);
}

.weather-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weather-city {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.weather-detail {
  font-size: 24rpx;
  color: #555555;
}

/* 主内容区 */
.model-area {
  flex: 1;
  position: relative;
  min-height: 0;
  padding: 120rpx 24rpx 140rpx;
  overflow: hidden;
}

.model-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #A8D8F0 0%, #B8E0F0 40%, #C5E8F5 100%);
  z-index: 0;
}

/* 天气动画层：位于背景之上、模特之下 */
.weather-animation {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

/* 晴天：阳光射线 */
.weather-sun-rays {
  position: absolute;
  left: 50%;
  top: -20%;
  width: 200%;
  height: 80%;
  margin-left: -100%;
  background: radial-gradient(
    ellipse 80% 50% at 50% 0%,
    rgba(255, 255, 255, 0.4) 0%,
    rgba(255, 220, 150, 0.15) 30%,
    transparent 70%
  );
  animation: sunRaysPulse 4s ease-in-out infinite;
}

@keyframes sunRaysPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.85; transform: scale(1.02); }
}

.weather-sun-glow {
  position: absolute;
  left: 50%;
  top: -30%;
  width: 120%;
  height: 60%;
  margin-left: -60%;
  background: radial-gradient(
    ellipse 60% 40% at 50% 0%,
    rgba(255, 255, 200, 0.25) 0%,
    transparent 60%
  );
  animation: sunGlow 8s ease-in-out infinite;
}

@keyframes sunGlow {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

/* 多云/阴：云朵飘动 */
.weather-cloud {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.65);
  box-shadow: 40rpx 20rpx 0 -10rpx rgba(255, 255, 255, 0.5);
  animation: cloudFloat 20s linear infinite;
}

.weather-animation-cloudy .weather-cloud {
  background: rgba(160, 170, 180, 0.55);
  box-shadow: 40rpx 20rpx 0 -10rpx rgba(140, 150, 160, 0.4);
  animation-duration: 28s;
}

.weather-cloud-1 {
  width: 140rpx;
  height: 70rpx;
  left: -15%;
  top: 12%;
  animation-delay: 0s;
}

.weather-cloud-2 {
  width: 160rpx;
  height: 80rpx;
  left: -20%;
  top: 32%;
  animation-delay: -7s;
}

.weather-cloud-3 {
  width: 110rpx;
  height: 55rpx;
  left: -12%;
  top: 52%;
  animation-delay: -14s;
}

@keyframes cloudFloat {
  0% { transform: translateX(0) translateY(0); opacity: 0.9; }
  100% { transform: translateX(800rpx) translateY(-15rpx); opacity: 0.9; }
}

/* 雨天：整体略暗 + 雨滴下落 */
.weather-animation-rain::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(100, 120, 140, 0.12);
  pointer-events: none;
}

.weather-rain {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
}

.rain-drop {
  position: absolute;
  width: 3rpx;
  height: 50rpx;
  top: -60rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.8), rgba(200, 220, 255, 0.4));
  border-radius: 2rpx;
  animation: rainFall 1.5s linear infinite;
}

.rain-drop-1 { left: 5%; animation-delay: 0s; }
.rain-drop-2 { left: 12%; animation-delay: 0.12s; }
.rain-drop-3 { left: 22%; animation-delay: 0.24s; }
.rain-drop-4 { left: 32%; animation-delay: 0.06s; }
.rain-drop-5 { left: 42%; animation-delay: 0.18s; }
.rain-drop-6 { left: 52%; animation-delay: 0.3s; }
.rain-drop-7 { left: 62%; animation-delay: 0.08s; }
.rain-drop-8 { left: 72%; animation-delay: 0.22s; }
.rain-drop-9 { left: 82%; animation-delay: 0.36s; }
.rain-drop-10 { left: 92%; animation-delay: 0.14s; }
.rain-drop-11 { left: 18%; animation-delay: 0.42s; }
.rain-drop-12 { left: 38%; animation-delay: 0.28s; }
.rain-drop-13 { left: 58%; animation-delay: 0.1s; }
.rain-drop-14 { left: 78%; animation-delay: 0.34s; }
.rain-drop-15 { left: 48%; animation-delay: 0.2s; }

@keyframes rainFall {
  0% { transform: translateY(0); opacity: 0.8; }
  100% { transform: translateY(calc(100vh + 100rpx)); opacity: 0.3; }
}

/* 自定义背景图：在默认背景上层 + 模糊 + 遮罩 */
.model-bg-wrap {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  z-index: 1;
}

.model-bg-image {
  position: absolute;
  left: -20rpx;
  top: -20rpx;
  right: -20rpx;
  bottom: -20rpx;
  width: calc(100% + 40rpx);
  height: calc(100% + 40rpx);
  filter: blur(12rpx);
}

.model-bg-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(60, 60, 60, 0.2);
}

/* 模特占位 */
.model-3d-wrap {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  min-height: 400rpx;
}

.model-wrap {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 1040rpx;
  height: 1440rpx;
  z-index: 3;
}

.model-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: transparent;
}

.model-2d-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.model-fallback {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 40rpx;
  width: 100%;
  height: 100%;
}

.model-placeholder.avatar-female,
.model-placeholder.avatar-male {
  background: transparent;
}

.model-silhouette {
  width: 160rpx;
  height: 240rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 80rpx 80rpx 40rpx 40rpx;
}

.model-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.model-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* 精灵管家：右上角，不遮挡模特 */
.fairy-wrap {
  position: absolute;
  right: 24rpx;
  top: 140rpx;
  z-index: 5;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: nowrap;
}

.fairy-bubbles {
  position: relative;
  margin-right: 8rpx;
  margin-top: -50rpx;
  width: 350rpx;
  min-height: 72rpx;
}

.fairy-bubble {
  position: absolute;
  right: 0;
  top: 0;
  background: rgba(255, 255, 255, 0.85);
  padding: 12rpx 16rpx 12rpx 20rpx;
  border-radius: 20rpx;
  overflow: visible;
  opacity: 0;
  transform: translateY(6rpx);
  transition: opacity 0.4s ease, transform 0.4s ease;
  pointer-events: none;
}

.fairy-bubble-tail {
  position: absolute;
  right: -10rpx;
  bottom: 10rpx;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 8rpx 0 8rpx 12rpx;
  border-color: transparent transparent transparent rgba(255, 255, 255, 0.85);
}

.fairy-bubble-active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.fairy-bubble-long {
  min-width: 350rpx;
  padding-right: 12rpx;
  padding-left: 18rpx;
}

.fairy-bubble-text {
  font-size: 20rpx;
  color: #333333;
  white-space: nowrap;
}

.fairy-body {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  background: none;
}

.fairy-img {
  width: 100%;
  height: 100%;
  background: none;
}

.fairy-placeholder {
  width: 100%;
  height: 100%;
  background: none;
}

/* 右侧操作按钮：渐变遮罩 */
.action-btns-mask {
  position: fixed;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(to left, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.15) 50%, transparent 100%);
  z-index: 4;
  pointer-events: none;
}

/* 右侧操作按钮 */
.action-btns {
  position: fixed;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  z-index: 5;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(80, 80, 80, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

