.tab-text {
  font-size: 22rpx;
  color: #999999;
}

.tab-item.tab-active .tab-text {
  color: #4DD0E1;
  font-weight: 500;
}

/* 切换城市弹窗 */
.city-search-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.city-search-mask-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 0;
}

.city-switch-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 600rpx;
  max-height: 80vh;
  background: #FFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
}

.city-input-wrap {
  margin-bottom: 20rpx;
}

.city-switch-header {
  margin-bottom: 24rpx;
}

.city-switch-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.city-current-wrap {
  font-size: 28rpx;
  color: #666;
}

.city-current-label {
  color: #999;
}

.city-current-value {
  color: #4DD0E1;
  font-weight: 500;
  margin-left: 8rpx;
}

.city-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  background: #F5F5F5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.city-list-scroll {
  height: 480rpx;
  margin-bottom: 24rpx;
}

.city-list-inner {
  padding: 8rpx 0;
}

.city-item {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #F0F0F0;
}

.city-item:active {
  background: #F5F5F5;
}

.city-item-current {
  color: #4DD0E1;
  font-weight: 500;
  background: rgba(77, 208, 225, 0.08);
}

.city-list-empty {
  padding: 48rpx;
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

.city-switch-footer {
  flex-shrink: 0;
}

.city-search-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 40rpx;
  padding: 0;
  border: none;
}

.city-search-btn::after {
  border: none;
}

.city-search-btn.cancel {
  background: #F0F0F0;
  color: #666;
}

/* 角色信息录入浮层：半透明黑遮罩 + 圆角卡片 */
.role-entry-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.role-entry-mask-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 0;
}

.role-entry-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 620rpx;
  background: #FBF8F5;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.15);
  padding: 40rpx 36rpx 36rpx;
  box-sizing: border-box;
}

.role-entry-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.06);
  color: #666;
  font-size: 40rpx;
  line-height: 52rpx;
  text-align: center;
  z-index: 2;
}

.role-entry-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
}

.role-entry-avatar-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.role-entry-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #F0EDE8;
}

.role-entry-form {
  margin-bottom: 36rpx;
}

.role-field {
  margin-bottom: 28rpx;
}

.role-field-row {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.role-field.half {
  flex: 1;
  margin-bottom: 0;
}

.role-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.role-label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.role-label-row .role-label {
  margin-bottom: 0;
}

.role-label-muted {
  color: #B0B0B0;
}

.role-switch {
  transform: scale(0.85);
}

.role-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background: #F0EDE8;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.role-entry-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.role-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 0 64rpx;
}

.role-btn-save {
  background: #5DB8A8;
  color: #FFFFFF;
}

