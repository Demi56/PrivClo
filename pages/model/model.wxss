}

.role-entry-mask-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 0;
}

.role-entry-card {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 620rpx;
  background: #FBF8F5;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.15);
  padding: 40rpx 36rpx 36rpx;
