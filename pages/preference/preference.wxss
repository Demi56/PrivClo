/* 新用户偏好及资料收集页 - 可上下滑动 */

.page {
  min-height: 100vh;
  background-color: #FBF8F5;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.status-bar { width: 100%; flex-shrink: 0; }

.scroll-area { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }

.content { padding: 24rpx 40rpx 160rpx; box-sizing: border-box; }

.progress { display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 16rpx; margin-bottom: 48rpx; }
.progress-dot { width: 12rpx; height: 12rpx; border-radius: 6rpx; background-color: #E8E8E8; }
.progress-dot-active { width: 40rpx; height: 8rpx; border-radius: 4rpx; background-color: #333333; }

.title { display: block; font-size: 48rpx; font-weight: bold; color: #333333; line-height: 1.35; margin-bottom: 16rpx; }
.subtitle { display: block; font-size: 28rpx; color: #555555; margin-bottom: 56rpx; }

.section { margin-bottom: 48rpx; }
.section-title { display: block; font-size: 32rpx; font-weight: 500; color: #333333; margin-bottom: 24rpx; }
.section-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.section-hint { font-size: 26rpx; color: #66CCAA; }

.gender-row { display: flex; flex-direction: row; gap: 24rpx; }
.gender-card { flex: 1; height: 220rpx; border-radius: 24rpx; background-color: #FFFFFF; border: 2rpx solid #E8E8E8; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; }
.gender-card.selected { background-color: #66CCAA; border-color: #66CCAA; }
.gender-icon-wrap { width: 80rpx; height: 80rpx; border-radius: 50%; background-color: rgba(0,0,0,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 16rpx; }
.gender-card.selected .gender-icon-wrap { background-color: rgba(255,255,255,0.35); }
.gender-icon { font-size: 40rpx; color: #999999; }
.gender-card.selected .gender-icon { color: #FFFFFF; }
.gender-label { font-size: 28rpx; color: #555555; }
.gender-card.selected .gender-label { color: #FFFFFF; }
.gender-check { position: absolute; top: 16rpx; right: 16rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background-color: rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center; }
.gender-check-inner { font-size: 22rpx; color: #66CCAA; font-weight: bold; }

.age-value { font-size: 32rpx; font-weight: bold; color: #333333; }
.slider-wrap { padding: 0 8rpx; margin-bottom: 8rpx; }
.slider { width: 100%; }
.slider-labels { display: flex; flex-direction: row; justify-content: space-between; padding: 0 8rpx; }
.slider-label { font-size: 24rpx; color: #999999; }

.section-style { margin-bottom: 80rpx; }
.tags { display: flex; flex-direction: row; flex-wrap: wrap; gap: 20rpx; }
.tag { padding: 20rpx 32rpx; border-radius: 40rpx; background-color: #FFFFFF; border: 2rpx solid #E8E8E8; font-size: 28rpx; color: #333333; }
.tag.selected { background-color: #66CCAA; border-color: #66CCAA; color: #FFFFFF; box-shadow: 0 4rpx 12rpx rgba(102,204,170,0.35); }
.tag-more { background-color: transparent; border-style: dashed; color: #66CCAA; }
.tag-more.expanded { color: #999999; }
.tags-more { margin-top: 20rpx; }

.bottom-pad { height: 40rpx; }

.float-btn { position: fixed; right: 40rpx; bottom: calc(80rpx + env(safe-area-inset-bottom)); width: 112rpx; height: 112rpx; border-radius: 56rpx; background-color: #333333; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2); }
.float-btn-arrow { width: 24rpx; height: 24rpx; border-top: 4rpx solid #FFFFFF; border-right: 4rpx solid #FFFFFF; transform: rotate(45deg); margin-left: -4rpx; }
