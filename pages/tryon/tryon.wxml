<!-- pages/tryon/tryon.wxml -->
<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" catchtap="onBack">
      <text class="back-icon">←</text>
      <text>返回</text>
    </view>
    <text class="nav-title">实时试穿</text>
    <view class="mode-toggle" wx:if="{{use3DTryon}}" bindtap="toggleTryonMode">
      <text>{{tryon3DFallback ? '切 3D' : '切 2D'}}</text>
    </view>
    <view class="placeholder" wx:else></view>
  </view>

  <!-- 顶部编辑对象：上衣 / 下装 / 套装（与下方手动调整、衣橱分类联动） -->
  <view class="tryon-top-tabs">
    <view class="tryon-top-tab {{adjustSlot === 'top' ? 'active' : ''}}" bindtap="selectTryonTopTab" data-tab="top">上衣</view>
    <view class="tryon-top-tab {{adjustSlot === 'bottom' ? 'active' : ''}}" bindtap="selectTryonTopTab" data-tab="bottom">下装</view>
    <view class="tryon-top-tab {{adjustSlot === 'dress' ? 'active' : ''}}" bindtap="selectTryonTopTab" data-tab="suit">套装</view>
  </view>

  <!-- 试穿区：优先 3D，失败或未支持时降级 2D Canvas -->
  <view class="tryon-stage" style="min-height: {{xrSceneHeight}}px;">
    <tryon-xr
      wx:if="{{use3DTryon && !tryon3DFallback}}"
      id="tryonXr"
      gender="{{gender}}"
      outfit="{{outfit}}"
      scene-height="{{xrSceneHeight}}"
      binderror="onTryon3DError"
    />
    <model-tryon
      wx:else
      id="modelTryon"
      gender="{{gender}}"
      outfit="{{outfit}}"
      editingSlot="{{adjustSlot}}"
      manualAdjustments="{{manualAdjustments}}"
      bindadjustmentchange="onAdjustmentsChange"
      bindmeshinit="onMeshInit"
      bindmeshdragend="onMeshDragEnd"
      bindslotswitch="onSlotSwitch"
    />
  </view>

  <view class="adjust-panel" wx:if="{{tryon3DFallback || !use3DTryon}}">
    <view class="adjust-title">手动调整位置</view>
    <view class="adjust-slot-tabs">
      <view class="adjust-slot-item {{adjustSlot === 'top' ? 'active' : ''}}" data-slot="top" bindtap="selectAdjustSlot">上衣</view>
      <view class="adjust-slot-item {{adjustSlot === 'bottom' ? 'active' : ''}}" data-slot="bottom" bindtap="selectAdjustSlot">下装</view>
      <view class="adjust-slot-item {{adjustSlot === 'dress' ? 'active' : ''}}" data-slot="dress" bindtap="selectAdjustSlot">连衣裙</view>
      <view class="adjust-slot-item {{adjustSlot === 'shoes' ? 'active' : ''}}" data-slot="shoes" bindtap="selectAdjustSlot">鞋子</view>
    </view>
    <view class="adjust-pad">
      <view class="adjust-row">
        <view class="adjust-btn" data-direction="up" bindtap="nudgeClothing">上移</view>
      </view>
      <view class="adjust-row">
        <view class="adjust-btn" data-direction="left" bindtap="nudgeClothing">左移</view>
        <view class="adjust-btn reset" bindtap="resetAdjustSlot">重置</view>
        <view class="adjust-btn" data-direction="right" bindtap="nudgeClothing">右移</view>
      </view>
      <view class="adjust-row">
        <view class="adjust-btn" data-direction="down" bindtap="nudgeClothing">下移</view>
      </view>
      <view class="adjust-row adjust-row-history">
        <view class="adjust-btn history" bindtap="onMeshUndo">撤销变形</view>
        <view class="adjust-btn history" bindtap="onMeshRedo">重做变形</view>
      </view>
    </view>
  </view>

  <!-- 衣物类别切换 -->
  <view class="category-bar">
    <view 
      wx:for="{{categories}}" 
      wx:key="key"
      class="category-item {{selectedCategory === item.key ? 'active' : ''}}"
      bindtap="switchCategory"
      data-category="{{item.key}}"
    >
      <text>{{item.icon}}</text>
      <text>{{item.name}}</text>
    </view>
  </view>

  <!-- 衣橱物品栏 -->
  <view class="wardrobe-bar">
    <scroll-view scroll-x class="wardrobe-scroll" wx:if="{{wardrobeItems.length > 0}}">
      <view 
        wx:for="{{wardrobeItems}}" 
        wx:key="_id"
        class="wardrobe-item"
        bindtap="selectClothing"
        data-item="{{item}}"
        wx:if="{{item.category === selectedCategory}}"
      >
        <image src="{{item.imageUrl}}" mode="aspectFill"></image>
        <text>{{item.name || item.category}}</text>
      </view>
    </scroll-view>
    <view class="empty-wardrobe" wx:else>
      <text>暂无衣物，请先去添加</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <button class="action-btn clear" bindtap="clearOutfit">清空</button>
    <button class="action-btn save" bindtap="saveOutfitImage">保存穿搭照</button>
  </view>
</view>