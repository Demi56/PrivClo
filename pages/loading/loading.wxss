/* 加载过渡页 - 参考设计图 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #EFF6FC 0%, #D4EDFA 35%, #A7E0F6 70%, #7DD3FC 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
}

.status-bar {
  width: 100%;
  flex-shrink: 0;
}

.content {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx 80rpx;
}

/* 精灵插图卡片 */
.sprite-card {
  width: 420rpx;
  height: 420rpx;
  background: transparent;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(125, 211, 252, 0.25), 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 56rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.sprite-img {
  width: 100%;
  height: 100%;
}

/* 标题区 */
.text-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 120rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.tagline {
  font-size: 28rpx;
  font-weight: 400;
  color: #4B5563;
  letter-spacing: 1rpx;
}

/* 底部加载区 */
.loading-footer {
  width: 100%;
  max-width: 520rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
}

.loading-label {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(75, 85, 99, 0.85);
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.loading-bar-wrap {
  flex: 1;
  min-width: 0;
}

.loading-bar-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
}

.loading-bar-fill {
  height: 100%;
  background: rgba(125, 211, 252, 0.9);
  border-radius: 6rpx;
  transition: width 0.08s ease;
}

.version {
  font-size: 22rpx;
  font-weight: 500;
  color: rgba(75, 85, 99, 0.85);
  flex-shrink: 0;
}
