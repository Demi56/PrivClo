<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">街拍转穿搭</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="content">
    <view class="upload-area" bindtap="chooseImage">
      <image wx:if="{{uploadedImage}}" class="upload-img" src="{{uploadedImage}}" mode="aspectFill" />
      <view wx:else class="upload-placeholder">
        <text class="icon">📸</text>
        <text class="label">上传街拍照片</text>
        <text class="tip">支持小红书、Instagram 穿搭截图</text>
      </view>
      <view wx:if="{{loading}}" class="upload-loading">
        <text>AI 分析中...</text>
      </view>
    </view>

    <view class="result-area" wx:if="{{analysis}}">
      <view class="ai-result-tag">✨ AI推荐 · 仅供参考</view>
      <view class="style-tag">{{analysis.style}}</view>
      <view class="clothing-list">
        <view class="clothing-item" wx:for="{{clothingList}}" wx:key="index">
          <view class="category">{{item.category}}</view>
          <view class="description">{{item.description}}</view>
          <button class="match-btn" catchtap="matchToWardrobe" data-item="{{item}}">匹配衣橱</button>
        </view>
      </view>

      <image wx:if="{{cardImage}}" class="card-image" src="{{cardImage}}" mode="widthFix" />
      <text wx:if="{{tip}}" class="fallback-tip">{{tip}}</text>

      <button class="btn-save" bindtap="saveToDiary">保存为穿搭灵感</button>
      <button class="btn-album" bindtap="saveToAlbum">保存到相册</button>
    </view>
  </view>

  <canvas type="2d" id="aiWatermarkCanvas" class="ai-watermark-canvas"></canvas>
</view>
