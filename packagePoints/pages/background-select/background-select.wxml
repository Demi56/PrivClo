<!-- 背景选择 - 我的背景，仅公园小路卡片 -->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">我的背景</text>
    <view class="header-placeholder"></view>
  </view>

  <!-- 两列商品网格（仅公园小路） -->
  <scroll-view class="product-scroll" scroll-y>
    <view class="product-grid">
      <view wx:for="{{displayList}}" wx:key="id" class="product-card">
        <view class="product-img-wrap">
          <image wx:if="{{item.image}}" class="product-img" src="{{item.image}}" mode="aspectFill" />
          <view wx:else class="product-img product-img-placeholder"></view>
        </view>
        <text class="product-name">{{item.name}}</text>
        <view class="product-row">
          <view class="product-btn" catchtap="onUse" data-id="{{item.id}}" data-image="{{item.image}}">{{item.image === currentBgImage ? '已使用' : '使用'}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
