<!--
  邀请好友 - 分享确认界面
  布局：顶栏 | 插画 | 邀请文案卡 | 邀请卡(二维码+邀请码) | 分享方式 | 已邀请好友列表
-->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">邀请好友</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="content" scroll-y enable-flex>
    <view class="content-inner">
    <!-- 插画区：小精灵管家 -->
    <view class="illustration-wrap">
      <view class="illustration-placeholder">
        <image class="sprite-img" src="{{spriteUrl}}" mode="aspectFit" />
      </view>
    </view>

    <!-- 邀请文案卡 -->
    <view class="invite-detail-card">
      <text class="invite-headline">邀请好友，各得<text class="highlight">1000积分</text></text>
      <text class="invite-desc">分享专属链接给好友，注册成功后双方账户将各获得1000积分奖励</text>
    </view>

    <!-- 邀请卡：二维码 + 邀请码 -->
    <view class="invite-card-wrap">
      <view class="invite-card-header">
        <view class="invite-card-avatar"></view>
        <text class="invite-card-title">{{roleName}}的邀请卡</text>
      </view>
      <view class="qr-area">
        <view class="qr-placeholder">
          <text class="qr-hint">二维码</text>
        </view>
        <text class="invite-code-label">我的专属邀请码</text>
        <view class="invite-code-row">
          <text class="invite-code-value">{{inviteCode}}</text>
          <view class="icon-copy" bindtap="onCopyCode"></view>
        </view>
        <view class="scan-link">
          <view class="icon-scan"></view>
          <text class="scan-text">扫码立即加入</text>
        </view>
      </view>
    </view>

    <!-- 分享方式：微信 | QQ | 复制链接 -->
    <view class="share-options">
      <view class="share-btn" bindtap="onShareWechat">
        <view class="share-icon share-icon-wechat"></view>
        <text class="share-label">微信</text>
      </view>
      <view class="share-btn" bindtap="onShareQQ">
        <view class="share-icon share-icon-qq"></view>
        <text class="share-label">QQ</text>
      </view>
      <view class="share-btn" bindtap="onCopyLink">
        <view class="share-icon share-icon-link"></view>
        <text class="share-label">复制链接</text>
      </view>
    </view>

    <!-- 已成功邀请的好友 -->
    <view class="invited-section">
      <view class="invited-header">
        <text class="invited-title">已成功邀请的好友</text>
        <text class="invited-viewall" bindtap="onViewAll">查看全部</text>
      </view>
      <view class="invited-list">
        <view class="invited-item" wx:for="{{invitedList}}" wx:key="id">
          <view class="invited-avatar invited-avatar-{{index % 3}}"></view>
          <view class="invited-info">
            <text class="invited-name">{{item.name}}</text>
            <text class="invited-time">{{item.time}}</text>
          </view>
          <view class="invited-points">
            <view class="points-icon-small"></view>
            <text class="points-num">+1000</text>
          </view>
        </view>
      </view>
    </view>
    </view>
  </scroll-view>
</view>
