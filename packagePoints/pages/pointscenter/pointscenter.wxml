<!--
  积分中心 - 收入与支出明细
  布局：当前积分 | 分享按钮 | 明细列表（活动名/积分数值/交易时间）
-->
<view class="page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="nav-header">
    <view class="header-back" bindtap="onBack">
      <view class="header-back-arrow"></view>
    </view>
    <text class="header-title">积分中心</text>
    <view class="header-placeholder"></view>
  </view>

  <!-- 顶部：当前积分 + 分享按钮 -->
  <view class="header">
    <view class="points-summary">
      <text class="points-label">当前积分</text>
      <text class="points-value">{{totalPoints}} pt</text>
    </view>
    <view class="header-buttons">
      <navigator class="btn-invite" url="/packagePoints/pages/invite/invite?roleName={{roleName}}">
        <text class="btn-invite-text">邀请好友</text>
      </navigator>
      <button class="btn-share" open-type="share">
        <view class="btn-share-icon"></view>
        <text class="btn-share-text">分享</text>
      </button>
    </view>
  </view>

  <!-- 明细列表 -->
  <view class="content">
    <view class="section-title">
      <text class="section-title-text">收支明细</text>
    </view>
    <view class="record-list">
      <view class="record-item {{item.type === 'income' ? 'record-income' : 'record-expense'}}" wx:for="{{recordList}}" wx:key="id">
        <view class="record-main">
          <text class="record-activity">{{item.activity}}</text>
          <text class="record-points {{item.type === 'income' ? 'points-green' : 'points-red'}}">{{item.points > 0 ? '+' : ''}}{{item.points}}</text>
        </view>
        <text class="record-time">{{item.time}}</text>
      </view>
      <view wx:if="{{recordList.length === 0}}" class="record-empty">暂无积分明细</view>
    </view>
  </view>
</view>
